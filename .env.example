# Copy to `.env` and fill in. Everything here is what YOU need to provide.
# The app runs without any of it while NEXT_PUBLIC_DATA_CLIENT="local".

# ── Database (Neon Postgres) ──────────────────────────────────────────────────

# Pooled connection string from Neon's connection-pooling tab (PgBouncer).
# Used by Prisma at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.aws.neon.tech/companio?sslmode=require&pgbouncer=true"

# Direct (non-pooled) connection string from Neon. Required for `prisma migrate`
# because PgBouncer does not support DDL transactions.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.aws.neon.tech/companio?sslmode=require"

# ── Auth.js (next-auth v4) ────────────────────────────────────────────────────

# Random 32-char secret used to sign JWTs/cookies. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-random-32-char-secret"

# Full public URL of the deployment (no trailing slash). For local dev:
#   http://localhost:3000
NEXTAUTH_URL="https://your-app.vercel.app"

# ── Auth provider — PICK ONE (then implement authorize() in lib/auth.ts) ──────
# The provider is still a STUB. Provide the credentials for your chosen method:

# Option A — Google OAuth:
# GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Option B — Phone OTP (SMS gateway, e.g. Twilio / MSG91):
# SMS_API_KEY="your_sms_gateway_key"
# SMS_SENDER_ID="COMPNO"

# ── Razorpay ──────────────────────────────────────────────────────────────────

# API key id from the Razorpay dashboard (also returned to the client checkout).
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"

# Same key id, exposed to the browser. WHY a separate var: only NEXT_PUBLIC_*
# vars reach client code, and the pay buttons use this as the live/demo gate —
# when it's absent the UI runs the local demo animation; when set, real Checkout.
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"

# API key secret — NEVER expose client-side or commit to git.
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

# Webhook signing secret (Razorpay dashboard → Webhooks → Secret).
# Verified in /api/razorpay/webhook against the raw request body.
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# ── Frontend data client ──────────────────────────────────────────────────────

# Which DataClient implementation lib/dataClient.ts uses:
#   'local' = localStorage mock (default, no backend needed)
#   'http'  = the real API routes (requires DATABASE_URL + NEXTAUTH_SECRET + a
#             working auth provider). Flip to 'http' only after migrate + seed.
NEXT_PUBLIC_DATA_CLIENT="local"

# ── Analytics & monitoring (OPTIONAL — the app runs fully without any of it) ───
# Every sink below is wired but dormant: unset = no-op. Paste a value to switch
# it on. Nothing fires until the visitor accepts the consent banner (DPDP/GDPR).

# Google Analytics 4 — GA Admin → Data Streams → measurement id "G-XXXXXXXXXX".
NEXT_PUBLIC_GA_ID=""

# PostHog product analytics (funnels, retention, autocapture). Consent-gated:
# the SDK only loads after the visitor accepts. EU projects: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Sentry error monitoring. The DSN is safe to expose in the browser; client and
# server read their own var. Unset = the Sentry SDK initialises disabled.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""

# ── Site URL + rate limiting ──────────────────────────────────────────────────

# Canonical public origin, no trailing slash. Drives SEO: sitemap, robots,
# canonical/OG URLs, JSON-LD. Defaults to http://localhost:3000 when unset.
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"

# Upstash Redis (optional) — distributed rate limiting across serverless
# instances. Without these, rate limiting falls back to per-instance in-memory.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Transactional email (optional) ────────────────────────────────────────────
# Resend API key (https://resend.com). Unset = email is dormant: booking
# confirmations and payment receipts are skipped, never error. Set to activate.
RESEND_API_KEY=""

# From address for outgoing mail. Must be a verified Resend domain in production.
EMAIL_FROM="Companio <hello@companio.app>"

# ── Cron (optional) ───────────────────────────────────────────────────────────
# Shared secret guarding GET /api/cron (auto-completes past bookings). Vercel
# Cron sends it as a Bearer token. Unset = the endpoint returns 503.
CRON_SECRET=""
