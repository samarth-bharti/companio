{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "node .claude/hooks/git-identity-guard.mjs",
            "statusMessage": "Checking git identity"
          }
        ]
      }
    ]
  }
}
