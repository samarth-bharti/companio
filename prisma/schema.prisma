// Companio — Postgres data model (Neon).
// THIS FILE IS NOT COMPILED BY NEXT.JS. It is safe to add before running
// `prisma migrate dev`. No npm package needed until you intentionally install
// prisma + @prisma/client.
//
// Run order when ready:
//   1. npm i prisma @prisma/client
//   2. Set DATABASE_URL + DIRECT_URL in .env
//   3. npx prisma migrate dev --name init
//   4. npx prisma db seed  (seed from lib/data/companions.ts)

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // pooled connection (PgBouncer / Neon pooler)
  directUrl = env("DIRECT_URL")     // direct connection needed for migrations
}

generator client {
  provider = "prisma-client-js"
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum BookingStatus {
  pending_payment // cash booking created, awaiting Razorpay settlement — NOT confirmed
  upcoming        // confirmed: paid by credit, or cash payment settled
  completed       // meetup date has passed (set by cron, never at payment time)
  cancelled       // called off by the member
  declined        // the companion refused it; the member's credit is returned
  refunded        // admin reversed the charge (credits returned / Razorpay refund)
}

// Result of the free, vendor-less document sanity checks (see
// lib/server/documentValidation.ts). 'manual' = admin approved by eye.
enum DocVerifyStatus {
  pending
  verified
  failed
  manual
}

enum DiscountType {
  percentage // value = 0–100 (% off)
  fixed      // value = paise off
}

enum ApplicationStatus {
  draft
  submitted
  approved
  rejected
}

enum MessageFrom {
  me
  them
}

enum MessageKind {
  text
  sticker
}

// Only the first three are a category we can MATCH on. `self_described` carries
// its text in User.genderSelfDescribed; `prefer_not_to_say` carries nothing.
// The same-gender filter needs a shared category on both sides, so those two
// cannot use it — and the UI says so rather than quietly matching them wrong.
enum Gender {
  male
  female
  nonbinary
  self_described
  prefer_not_to_say
}

enum PurchaseKind {
  booking
  credits
  unlock
  plus
}

enum PurchaseStatus {
  created
  paid
}

enum UserRole {
  user
  companion
  admin
}

// Server-generated spin outcomes. 'none' = the (most common) no-win result.
// Odds live in lib/server/spin.ts and are published under the wheel.
enum SpinPrize {
  none
  discount5   // 5% off the pass
  discount10  // 10% off the pass
  discount15  // 15% off the pass
  discount20  // 20% off the pass
  free_visit  // one extra included meeting — 0.01%
  plus_month  // retired: never drawn (kept so old rows still parse)
}

enum ReportTargetType {
  companion
  user
}

enum ReportStatus {
  open
  reviewing
  actioned
  dismissed
}

enum PayoutStatus {
  pending
  paid
}

// ── User ──────────────────────────────────────────────────────────────────────
// Mirrors DemoUser (firstName) + QuizResult (name, city, matchedId) and the
// fields expected from Auth.js OAuth / phone-OTP sign-in.

model User {
  id          String   @id @default(cuid())
  // Auth identifiers — at least one must be present
  phone       String?  @unique
  email       String?  @unique
  // Profile
  firstName   String
  lastName    String?
  gender      Gender?
  // Free text, only ever set when gender == self_described. Asking someone to
  // self-describe and then storing nothing was the old behaviour.
  genderSelfDescribed String?
  // "Only show me companions of my own gender." A comfort/safety preference the
  // member owns, honoured by the explore filter and settable outside the quiz.
  sameGenderOnly Boolean @default(false)
  city        String?  // matches City.id from lib/data/cities
  // Companio is 18+. Null means "we have never asked" — which is NOT an adult:
  // booking and companion applications refuse until it is set (lib/server/age.ts).
  // Google OAuth does not provide this, so it is collected once, after sign-in.
  dateOfBirth DateTime?
  role        UserRole @default(user) // gates admin panel + companion dashboard
  // The Companion profile this login owns (set when an application is approved).
  // null for ordinary members; @unique so one profile maps to one account.
  companionId String?  @unique
  // Onboarding flags (mirrors localStorage keys)
  welcomed    Boolean  @default(false)
  // The pass. `unlocked` says a pass was paid for; `unlockedUntil` says when it
  // lapses. NULL while unlocked = lifetime (the ₹1999 tier). Never read these
  // two directly — lib/server/viewer.ts#viewerHasUnlocked is the one chokepoint
  // that gets the "unlocked but expired" case right.
  unlocked       Boolean   @default(false)
  unlockedUntil  DateTime?
  // Quiz result — stored inline to avoid a join on every page load
  quizMatchId String?  // companion id matched by the onboarding quiz
  // Spin wheel — weekly cooldown gate (null = never spun)
  lastSpinAt  DateTime?
  // Moderation (admin-controlled). suspended = soft block (can't book/login flows
  // gate on it); bannedAt set = hard ban. messageBlocked silences messaging only.
  suspended      Boolean  @default(false)
  bannedAt       DateTime?
  banReason      String?
  messageBlocked Boolean  @default(false)
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  wallet         Wallet?
  bookings       Booking[]
  favorites      Favorite[]
  sentMessages   Message[]        @relation("SentBy")
  notifications  Notification[]
  subscription   Subscription?
  application    CompanionApplication?
  purchases      Purchase[]
  spins          SpinResult[]
  reportsMade    Report[]         @relation("ReportsMade")
  reportsAgainst Report[]         @relation("ReportsAgainst")
  companion      Companion?       @relation(fields: [companionId], references: [id])
  adminActions   AdminAuditLog[]  @relation("AdminActor")

  @@index([city])
  @@index([role])
  @@map("users")
}

// ── Email one-time codes ──────────────────────────────────────────────────────
// Sign-in codes for the passwordless email flow. The code itself is never
// stored: only a SHA-256 hash salted with NEXTAUTH_SECRET, so a database leak
// cannot be replayed into sessions. Rows are consumed on first successful use
// and swept by the cron job once expired.
model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  // Wrong guesses against this code. verifyOtp() refuses past MAX_OTP_ATTEMPTS,
  // which stops a 10-minute window from being brute-forced across 1e6 codes.
  attempts  Int      @default(0)
  consumedAt DateTime?
  createdAt DateTime @default(now())

  @@index([email, expiresAt])
  @@map("email_otps")
}

// ── Contact messages ──────────────────────────────────────────────────────────
// Submissions from /contact. Persisted first, emailed second: if Resend is down
// the message is still on record rather than lost to a failed fetch.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  topic     String
  message   String
  // Set once the notification email actually left Resend.
  emailedAt DateTime?
  handledAt DateTime?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("contact_messages")
}

// ── Wallet + Credit Ledger ────────────────────────────────────────────────────
// Wallet is 1:1 with User. CreditLedger is an append-only event log so we
// can reconstruct the balance from history and audit every top-up / spend.

model Wallet {
  id       String  @id @default(cuid())
  userId   String  @unique
  // One free included meeting, not two. The second was giving away the whole
  // trial before anyone had a reason to pay for a pass.
  credits  Int     @default(1)
  used     Int     @default(0)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledger   CreditLedger[]

  @@map("wallets")
}

// kind: "topup" | "spend" | "refund"
model CreditLedger {
  id        String   @id @default(cuid())
  walletId  String
  delta     Int      // positive = gain, negative = spend
  kind      String   // topup | spend | refund
  note      String?  // e.g. "Razorpay order_xxx" or "booking bk_..."
  createdAt DateTime @default(now())
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@map("credit_ledger")
}

// ── Companion ─────────────────────────────────────────────────────────────────
// Mirrors the Companion interface from lib/data/companions.ts exactly.
// reviewsList is stored as Json[] to avoid a full 4-table join on the
// explore page — denormalised on purpose. Formal reviews come via Booking.review.

model Companion {
  id             String   @id  // matches lib/data id strings e.g. 'ananya'
  name           String
  firstName      String
  maskedName     String
  city           String
  area           String
  age            Int?
  activities     String[] // e.g. ['City Walk', 'Café Chat', 'Museum']
  languages      String[]
  rating         Float    @default(0)
  reviewCount    Int      @default(0)  // `reviews` in the TS type
  ratePerMeeting Int      // legacy flat rate (paise) — kept for back-compat
  hourlyRate     Int      @default(50000) // paise/hour — variable ₹300–₹1000 (₹500 default)
  premium        Boolean  @default(false)  // premium companions priced up to ₹2000/hr
  bio            String
  suggestions    String[] // 3 city-specific outing ideas
  photo          String   // Unsplash URL
  accent         String   // hex colour string
  // The companion's own gender. Null = never declared, which is NOT a match for
  // anyone: a member who asked for same-gender company must not be shown someone
  // whose gender we are guessing at. Required by the application form, so every
  // real companion has one; nullable only so the column could be added.
  gender         Gender?
  sameGenderNote Boolean  @default(false)
  topMatch       Boolean  @default(false)
  verified       Boolean  @default(false)
  // Moderation (admin-controlled). suspended hides the profile from explore +
  // blocks new bookings; bannedAt set = permanently removed from the marketplace.
  suspended      Boolean  @default(false)
  bannedAt       DateTime?
  banReason      String?
  // Where this companion is paid. Collected in the companion dashboard; read by
  // an admin when settling a CompanionPayout. Nullable: a companion with no
  // payout method simply cannot be paid yet, and the admin payouts page says so.
  payoutUpi      String?
  // Presence + smart-match fields
  availableNow   Boolean  @default(false)
  availability   String   @default("Available tomorrow")
  distanceKm     Float    @default(5)
  matchScore     Int      @default(70) // 0–100
  // Denormalised reviews snapshot (Json array of {name,city,stars,text})
  reviewsList    Json     @default("[]")
  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  bookings       Booking[]
  favorites      Favorite[]
  messages       Message[]
  payouts        CompanionPayout[]
  account        User?            // the login that owns this profile (if any)

  @@index([city, availableNow])
  @@index([city, matchScore])
  @@map("companions")
}

// ── Booking ───────────────────────────────────────────────────────────────────
// Mirrors the Booking interface from lib/appState.ts.
// review is stored inline as Json to avoid a separate table for v1.

model Booking {
  id          String        @id @default(cuid())
  userId      String
  companionId String
  activity    String
  dateISO     String        // e.g. '2026-06-15' — kept as string to match frontend
  time        String        // display slot e.g. 'Morning · 7–9 AM'
  place       String
  status      BookingStatus @default(upcoming)
  // The 4-digit code both people read out when they meet, so each knows the other
  // is the person from the app. /verify has always told members to compare it —
  // it just never existed, which made the instruction worse than useless: a member
  // who could not find a code would assume the real companion was an impostor.
  // Every Indian already knows this ritual from a ride app's OTP.
  meetupCode  String        @default("")
  usedCredit  Boolean       @default(false)
  hours       Int           @default(1) // session length — total = hourlyRate × hours
  pricePaid   Int           @default(0) // paise the user actually paid (after discount/surge)
  // Money split — set server-side at settle time (see lib/server/pricing.ts)
  commissionPaise Int       @default(0) // platform cut (30% std / 10% Plus)
  payoutPaise     Int       @default(0) // companion earns this (pricePaid − commission)
  surgeMultiplier Float     @default(1) // peak/festival multiplier applied
  spinDiscountPct Int       @default(0) // redeemed spin-wheel discount, 0–100
  discountCode    String?   // admin/coupon code applied at checkout, if any
  review      Json?         // { stars: number, text: string } | null
  // Payment traceability — never lose the tx hash
  razorpayOrderId   String?
  razorpayPaymentId String?
  // Refund trail — set when an admin reverses the booking (status → refunded)
  refundedAt   DateTime?
  refundReason String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  companion   Companion     @relation(fields: [companionId], references: [id])
  payout      CompanionPayout?

  @@index([userId, status])
  @@index([companionId, dateISO])
  @@map("bookings")
}

// ── Subscription / Plus Plan ──────────────────────────────────────────────────
// Mirrors Plan ('plus' | null) from lib/appState.ts.

model Subscription {
  id                String    @id @default(cuid())
  userId            String    @unique
  plan              String    // 'plus' — extensible for future tiers
  startsAt          DateTime  @default(now())
  endsAt            DateTime?
  razorpaySubId     String?   // Razorpay subscription id for recurring billing
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ── Purchase ──────────────────────────────────────────────────────────────────
// Server-authoritative payment intent. The client names WHAT it buys (kind +
// packId); the SERVER fixes the amount + credits from lib/server/pricing.ts.
// The paid benefit (credits / unlock / plus / booking-complete) is granted ONLY
// inside settlePurchase() after HMAC verification — never by a client setter.

model Purchase {
  id                String         @id @default(cuid())
  // Nullable, and SetNull on erasure — NOT Cascade. The privacy policy promises
  // that payment and tax records survive account deletion ("typically kept for
  // up to 8 years"), and cascading deleted them: an erased member took the
  // company's own accounting trail with them, and the admin revenue figure
  // silently shrank. Erasure now severs the buyer from the payment instead of
  // destroying the payment. A null userId means "the buyer exercised their right
  // to be forgotten"; the money still happened.
  userId            String?
  kind              PurchaseKind
  amount            Int            // paise — server-decided, never client-supplied
  credits           Int            @default(0) // granted on settle (kind = credits)
  // Which pass tier was bought (kind = unlock): pass1m | pass3m | pass12m |
  // passlife. Recorded so settle knows how long to extend the pass, and so a
  // receipt can name what was sold. Null on pre-ladder rows.
  passTier          String?
  bookingId         String?        // set when kind = booking
  spinResultId      String?        // spin win redeemed on this booking, if any
  // Discount code applied to this order, upper-cased. Recorded at order time and
  // read on settle, which is when the code's usedCount is actually incremented —
  // an abandoned checkout must not burn a use.
  discountCode      String?
  status            PurchaseStatus @default(created)
  razorpayOrderId   String         @unique
  razorpayPaymentId String?
  // GST invoice — populated on settle once GST registration is live (post-launch).
  invoiceNo         String?        @unique // e.g. CMPN-2026-000123
  gstPaise          Int            @default(0) // 18% GST component of `amount`
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@map("purchases")
}

// ── Message ───────────────────────────────────────────────────────────────────
// One thread per (userId, companionId) pair. threadId = userId_companionId.
// Mirrors ChatMessage from lib/appState.ts.

model Message {
  id          String      @id @default(cuid())
  threadId    String      // composite key string for easy lookup
  userId      String
  companionId String
  from        MessageFrom // 'me' | 'them'
  text        String
  // A sticker is a single emoji rendered large. Without this column the POST
  // route dropped `kind` and a sticker came back from the server as a small
  // text bubble on the next load.
  kind        MessageKind @default(text)
  // Emoji reactions on this message. Held on the message itself rather than in
  // a join table: they are a short, unordered set owned by the one member who
  // can see the thread, and nothing queries across them.
  reactions   String[]    @default([])
  ts          BigInt      // epoch ms — matches the number in ChatMessage
  createdAt   DateTime    @default(now())

  user        User        @relation("SentBy", fields: [userId], references: [id], onDelete: Cascade)
  companion   Companion   @relation(fields: [companionId], references: [id])

  @@index([threadId, createdAt])
  @@map("messages")
}

// ── Notification ──────────────────────────────────────────────────────────────
// Mirrors AppNotification from lib/appState.ts.

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  ts        BigInt   // epoch ms
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

// ── Favorite ──────────────────────────────────────────────────────────────────

model Favorite {
  userId      String
  companionId String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companion   Companion @relation(fields: [companionId], references: [id])

  @@id([userId, companionId])
  @@map("favorites")
}

// ── Companion Application ─────────────────────────────────────────────────────
// Mirrors CompanionApplication from lib/appState.ts. One draft per user.

model CompanionApplication {
  id                String            @id @default(cuid())
  userId            String            @unique
  name              String
  city              String
  // Collected because the same-gender filter is a safety promise to members, and
  // a companion with no declared gender matches nobody who asked for one. An
  // approved applicant used to arrive with no gender at all, which made every
  // real companion invisible to the very members most likely to need the filter.
  gender            Gender?
  activities        String[]
  rate              Int               // ratePerMeeting in paise
  bio               String
  idUploaded        Boolean           @default(false)
  backgroundConsent Boolean           @default(false)
  status            ApplicationStatus @default(draft)
  // Free document-sanity results (lib/server/documentValidation.ts). We store the
  // MASKED number + a hash only — never the full Aadhaar (DPDPA liability).
  idDocType         String?           // 'aadhaar' | 'pan'
  idDocMasked       String?           // e.g. "XXXX XXXX 2346"
  idHash            String?           // sha256 of the uploaded ID file (dup block)
  photoHash         String?           // sha256 of the uploaded selfie (dup block)
  idVerifyStatus    DocVerifyStatus   @default(pending)
  photoVerifyStatus DocVerifyStatus   @default(pending)
  ocrMatched        Boolean?          // did OCR find the typed number on the image
  verifiedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([idHash])
  @@map("companion_applications")
}

// ── Spin Wheel ────────────────────────────────────────────────────────────────
// Weekly spin. The OUTCOME IS DECIDED SERVER-SIDE in /api/spin and stored here —
// the client only animates to a result it cannot influence (prevents devtools
// "I won" forgery). A non-`none`, unused, unexpired row is redeemable once at
// checkout, which stamps `usedBookingId` so it can't be reused.
model SpinResult {
  id            String    @id @default(cuid())
  userId        String
  prize         SpinPrize
  discountPct   Int       @default(0) // 0 / 10 / 20 — mirrors prize for fast checkout math
  expiresAt     DateTime  // 7 days after the spin
  usedBookingId String?   // the booking it was spent on, when it was spent on one
  // Redeemed-or-not. This used to be `usedBookingId != null`, which meant a win
  // could only ever be spent on a BOOKING — and bookings are exactly what the
  // RBI Payment Aggregator gate makes unsellable (see lib/server/pricing.ts).
  // Every discount the wheel handed out was therefore unspendable: the same
  // defect that got the `plus_month` jackpot deleted. A win now applies to the
  // one thing v1 actually sells, so redemption is no longer booking-shaped.
  usedAt        DateTime?
  usedPurchaseId String?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("spin_results")
}

// ── Report / Block ────────────────────────────────────────────────────────────
// IT Act intermediary duty: a working report → review → action trail.
// reporterId is the signed-in user; target is a companion id (string) or a user id.
model Report {
  id          String           @id @default(cuid())
  reporterId  String
  targetType  ReportTargetType
  companionId String?          // set when targetType = companion
  targetUserId String?         // set when targetType = user
  reason      String           // short category
  detail      String?          // free-text description
  status      ReportStatus     @default(open)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  reporter    User             @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser  User?            @relation("ReportsAgainst", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([companionId])
  @@map("reports")
}

// ── Companion Payout ──────────────────────────────────────────────────────────
// One payout row per completed, paid booking. Created at settle time with the
// post-commission amount so the admin/companion dashboards can show "owed" vs
// "paid" without recomputing from money flows.
model CompanionPayout {
  id          String       @id @default(cuid())
  companionId String
  // Nullable, and SetNull when the booking goes — NOT Cascade. A member erasing
  // their account deleted their bookings, and the cascade took the companion's
  // *unpaid wage* with them: the meetup happened, the money was owed, and the
  // row vanished because someone unrelated exercised a privacy right. The payout
  // carries its own companionId and amountPaise, so it survives on its own.
  bookingId   String?      @unique
  amountPaise Int          // == Booking.payoutPaise at settle time
  status      PayoutStatus @default(pending)
  paidAt      DateTime?
  reference   String?      // bank/UPI txn ref once paid
  createdAt   DateTime     @default(now())
  companion   Companion    @relation(fields: [companionId], references: [id])
  booking     Booking?     @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([companionId, status])
  @@map("companion_payouts")
}

// ── Surge Period ──────────────────────────────────────────────────────────────
// Admin-defined peak windows (festivals, weekends). Booking price is multiplied
// by `multiplier` when the booking date falls inside an active window. Resolved
// server-side in lib/server/pricing.ts — never trusted from the client.
model SurgePeriod {
  id          String   @id @default(cuid())
  label       String   // e.g. "Diwali weekend"
  startsAt    DateTime
  endsAt      DateTime
  multiplier  Float    @default(1.0) // e.g. 1.5 = +50%
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([active, startsAt, endsAt])
  @@map("surge_periods")
}

// ── Discount Code / Coupon ─────────────────────────────────────────────────────
// Admin-created promo codes. Applied at checkout server-side (never trusted from
// the client). Honours maxUses + expiry; usedCount increments on redemption.
model DiscountCode {
  id          String       @id @default(cuid())
  code        String       @unique // case-insensitive match — store upper-cased
  type        DiscountType @default(percentage)
  value       Int          // percentage 0–100, or paise when type = fixed
  maxUses     Int?         // null = unlimited
  usedCount   Int          @default(0)
  expiresAt   DateTime?    // null = never expires
  active      Boolean      @default(true)
  note        String?      // admin-facing memo (e.g. "Launch week")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([active, expiresAt])
  @@map("discount_codes")
}

// ── Admin Audit Log ────────────────────────────────────────────────────────────
// Every privileged admin mutation is recorded here — who did what, to whom, when.
// Non-negotiable for an MNC-grade control panel: accountability + dispute trail.
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // e.g. 'suspendUser', 'grantCredits', 'refundBooking'
  targetType String   // 'user' | 'companion' | 'booking' | 'discount' | 'application'
  targetId   String
  detail     String?  // JSON/string snapshot of the change (reason, amounts…)
  createdAt  DateTime @default(now())
  admin      User     @relation("AdminActor", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@map("admin_audit_logs")
}

// ── Social layer stubs (future) ───────────────────────────────────────────────
// Commented out to keep the initial migration small. Uncomment + migrate
// when the social/lounge feature is scoped.

// model Lounge {
//   id          String         @id @default(cuid())
//   name        String         // e.g. "Bandra Wanderers"
